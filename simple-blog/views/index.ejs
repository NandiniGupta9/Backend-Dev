<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Blog Posts</h1>

<a href="/new">Create New Post</a>

<% posts.forEach((post, index) => { %>
  <p>
    <a href="/posts/<%= index %>"><%= post.title %></a>
  </p>
<% }) %>
</body>
</html>
